import pandas as pd

def basic_eda(file):
    df = pd.read_csv(file)

    print("\n📌 Informações gerais:")
    print(df.info())

    print("\n📌 Primeiras linhas:")
    print(df.head())

    print("\n📌 Estatísticas descritivas:")
    print(df.describe())

    print("\n📌 Valores nulos:")
    print(df.isnull().sum())

if __name__ == "__main__":
    file = input("Digite o caminho do arquivo CSV: ")
    basic_eda(file)
